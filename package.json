{
  "name": "npm-verify-guard",
  "version": "1.0.0",
  "description": "Global npm vulnerability and malware verifier with install-time blocking",
  "type": "module",
  "bin": {
    "npm-verify": "./bin/npm-verify.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jhony2488/npm-verify-guard.git"
  },
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "generate-models": "node scripts/generate-models.mjs",
    "update-malware-hashes": "node scripts/update-malware-hashes.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.20.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "keywords": [
    "npm",
    "security",
    "vulnerability",
    "malware",
    "supply-chain",
    "cli",
    "npm-audit",
    "dependency-scanner",
    "node-modules",
    "osv",
    "cve",
    "rss",
    "postinstall",
    "npm-hooks",
    "supply-chain-security",
    "javascript",
    "nodejs",
    "verifier",
    "scanner",
    "typosquatting",
    "machine-learning",
    "onnx",
    "npm-security",
    "npm-malware",
    "dependency-check",
    "dependency-security",
    "malware-detection",
    "malware-scanner",
    "vulnerability-scanner",
    "security-scanner",
    "security-tool",
    "security-monitoring",
    "devsecops",
    "preinstall",
    "install-hook",
    "node-security",
    "static-analysis",
    "threat-detection",
    "software-composition-analysis",
    "sca",
    "open-source-security",
    "openssf",
    "nvd",
    "heuristic-analysis",
    "package-manager",
    "npm-verify",
    "npm-guard",
    "lockfile",
    "package-lock"
  ],
  "license": "MIT"
}
